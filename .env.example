# Copy to .env and fill in your values:  cp .env.example .env
# docker compose reads .env automatically.

# Anthropic / Claude API key (required for playlist generation).
ANTHROPIC_API_KEY=sk-ant-...

# YouTube Data API v3 key (required to search/resolve tracks).
# Create it in Google Cloud Console → enable "YouTube Data API v3" → Credentials → API key.
YOUTUBE_API_KEY=

# Optional: override the default Postgres connection used by docker-compose.
# DATABASE_URL=postgres://postgres:postgres@db:5432/moodtunes_development
