<% content_for :title, "#{@playlist.title} · MoodTunes" %>

<section data-playlist="<%= @playlist.slug %>" class="space-y-8 pb-40">
  <header class="rounded-2xl border border-white/10 bg-white/5 p-6 sm:p-8">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div class="min-w-0">
        <h1 class="text-2xl font-bold sm:text-3xl"><%= @playlist.title %></h1>
        <p class="mt-2 text-white/60">"<%= @playlist.description %>"</p>
        <div class="mt-3 flex flex-wrap gap-2 text-xs">
          <% if @playlist.mood.present? %>
            <span class="rounded-full bg-indigo-500/20 px-3 py-1 capitalize text-indigo-200"><%= @playlist.mood %></span>
          <% end %>
          <% Array(@playlist.genres).each do |genre| %>
            <span class="rounded-full bg-fuchsia-500/20 px-3 py-1 capitalize text-fuchsia-200"><%= genre %></span>
          <% end %>
        </div>
      </div>

      <% if @owner %>
        <%= button_to "↻ Rigenera playlist", regenerate_playlist_path(@playlist),
              method: :post,
              data: { turbo: false },
              class: "flex-none rounded-xl bg-indigo-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-indigo-400" %>
      <% end %>
    </div>

    <div class="mt-5 flex items-center gap-2 rounded-lg border border-white/10 bg-slate-900/60 px-3 py-2">
      <span class="text-xs text-white/40">Link condivisibile</span>
      <input type="text" readonly value="<%= playlist_url(@playlist) %>"
             onclick="this.select()"
             class="flex-1 truncate bg-transparent text-sm text-white/70 focus:outline-none">
    </div>
  </header>

  <% if @owner %>
    <div class="rounded-2xl border border-white/10 bg-white/5 p-6 sm:p-8">
      <h2 class="mb-3 text-sm font-medium">Aggiungi un brano</h2>
      <div class="relative">
        <input type="text" data-search-input
               placeholder="Cerca per titolo o artista..."
               autocomplete="off"
               class="w-full rounded-xl border border-white/10 bg-slate-900/60 px-4 py-3 text-white placeholder-white/30 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/40">
        <div data-search-results class="mt-2 space-y-1 empty:hidden"></div>
      </div>
    </div>
  <% end %>

  <div>
    <h2 class="mb-3 text-sm font-medium text-white/60">
      Brani <span data-track-count><%= @playlist.track_list.size %></span><% if @owner %> ·
      trascina per riordinare<% end %>
    </h2>
    <ul data-track-list class="space-y-2">
      <% @playlist.track_list.each do |track| %>
        <%= render partial: "playlists/track", locals: { track: track, playlist: @playlist, owner: @owner } %>
      <% end %>
    </ul>
  </div>

  <p class="text-center">
    <% if @owner %>
      <%= link_to "← Crea una nuova playlist", root_path,
            class: "text-sm text-indigo-300 hover:text-indigo-200" %>
    <% elsif logged_in? %>
      <%= link_to "← Crea la tua playlist", root_path,
            class: "text-sm text-indigo-300 hover:text-indigo-200" %>
    <% else %>
      <%= link_to "Crea le tue playlist su MoodTunes →", signup_path,
            class: "text-sm text-indigo-300 hover:text-indigo-200" %>
    <% end %>
  </p>

  <!-- Mini-player fisso: riproduzione continua dei video YouTube -->
  <div data-yt-player
       class="fixed inset-x-0 bottom-0 z-40 hidden border-t border-white/10 bg-slate-950/95 backdrop-blur">
    <div class="mx-auto flex max-w-4xl items-center gap-3 px-4 py-3">
      <div class="aspect-video w-40 flex-none overflow-hidden rounded-lg bg-black sm:w-56">
        <div id="yt-frame" class="h-full w-full"></div>
      </div>
      <div class="min-w-0 flex-1">
        <p class="text-xs uppercase tracking-wide text-white/40">In riproduzione</p>
        <p data-yt-title class="truncate font-medium">—</p>
        <p data-yt-artist class="truncate text-sm text-white/50"></p>
      </div>
      <button type="button" data-yt-close
              title="Chiudi player"
              class="flex-none rounded-lg border border-transparent px-2 py-1.5 text-white/40 transition hover:border-white/20 hover:text-white">
        ✕
      </button>
    </div>
  </div>
</section>
