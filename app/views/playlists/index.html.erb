<% content_for :title, "Le tue playlist · MoodTunes" %>

<section class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-2xl font-bold sm:text-3xl">Le tue playlist</h1>
    <%= link_to "+ Nuova playlist", root_path,
          class: "rounded-xl bg-indigo-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-indigo-400" %>
  </div>

  <% if @playlists.empty? %>
    <div class="rounded-2xl border border-white/10 bg-white/5 p-8 text-center text-white/60">
      Nessuna playlist ancora.
      <%= link_to "Creane una", root_path, class: "text-indigo-300 hover:text-indigo-200" %>.
    </div>
  <% else %>
    <ul class="space-y-3">
      <% @playlists.each do |playlist| %>
        <li class="flex items-center gap-4 rounded-xl border border-white/10 bg-white/5 px-4 py-4">
          <%= link_to playlist_path(playlist), class: "min-w-0 flex-1" do %>
            <p class="truncate font-semibold"><%= playlist.title %></p>
            <p class="mt-1 flex flex-wrap items-center gap-2 text-xs text-white/40">
              <span><%= playlist.track_list.size %> brani</span>
              <% if playlist.mood.present? %>
                <span class="rounded-full bg-indigo-500/20 px-2 py-0.5 capitalize text-indigo-200"><%= playlist.mood %></span>
              <% end %>
              <span>·</span>
              <span><%= playlist.created_at.strftime("%d/%m/%Y") %></span>
            </p>
          <% end %>

          <%= link_to "Apri →", playlist_path(playlist),
                class: "flex-none rounded-lg border border-white/10 px-3 py-1.5 text-xs font-medium text-white/70 transition hover:border-white/30 hover:text-white" %>

          <%= button_to "Elimina", playlist_path(playlist),
                method: :delete,
                data: { turbo: false },
                form: { onsubmit: "return confirm('Eliminare definitivamente questa playlist?')" },
                class: "flex-none rounded-lg border border-transparent px-3 py-1.5 text-xs text-white/40 transition hover:border-red-500/40 hover:text-red-300" %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <p class="text-center">
    <%= link_to "← Home", root_path, class: "text-sm text-indigo-300 hover:text-indigo-200" %>
  </p>
</section>
